{{- $searchIndex := slice -}}
{{- range $index, $element := .Site.RegularPages -}}
  {{- $searchIndex = $searchIndex | append
    (dict
      "id" $index
      "title" .Title
      "date" (.Date.Format "2006-01-02")
      "permalink" .RelPermalink
      "tags" (.Params.tags | default slice)
      "content" .Plain
      "summary" (.Summary | plainify)
    )
  -}}
{{- end -}}
{{- $searchIndex | jsonify -}}
